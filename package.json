{
  "name": "cafe-weather",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply cafe-weather --local",
    "db:seed:generate": "node scripts/generate-d1-seed.mjs",
    "db:seed:local": "wrangler d1 execute cafe-weather --local --file seed/dev.sql",
    "db:seed:remote": "wrangler d1 execute cafe-weather --remote --file seed/dev.sql",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "wrangler types",
    "preview": "npm run build && vite preview",
    "test": "NODE_OPTIONS=--disable-warning=ExperimentalWarning vitest run",
    "typecheck": "wrangler types && react-router typegen && tsc -b"
  },
  "dependencies": {
    "isbot": "^5.1.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  }
}
