{
  "name": "cafe-weather",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply cafe-weather --local",
    "db:reset:e2e": "wrangler d1 execute cafe-weather --local --command \"DELETE FROM reactions; DELETE FROM suggestions; DELETE FROM rate_limits;\"",
    "db:seed:generate": "node scripts/generate-d1-seed.mjs",
    "db:seed:local": "wrangler d1 execute cafe-weather --local --file seed/dev.sql",
    "db:seed:remote": "wrangler d1 execute cafe-weather --remote --file seed/dev.sql",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "lint": "eslint . --max-warnings 0",
    "postinstall": "wrangler types",
    "preview": "npm run build && vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "wrangler types && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "isbot": "^5.1.36",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.55.1",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  }
}
