# Copy these values to .dev.vars for local Wrangler development.
# Generate VISITOR_HMAC_SECRET with at least 32 random bytes. Never commit it.
VISITOR_HMAC_SECRET=

# Turnstile is optional for local development and required for suggestions in production.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
TURNSTILE_HOSTNAME=
TURNSTILE_ACTION=
